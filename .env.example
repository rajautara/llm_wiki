# OpenAI-compatible API configuration
# Leave OPENAI_API_KEY blank to force an explicit error before any chat call.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Default model used by ingest, query, and deep lint commands
WIKI_MODEL=gpt-4o

# SSL certificate verification
# Set to false, 0, off, or no only when you intentionally need to disable SSL verification.
WIKI_VERIFY_SSL=true

# Set to false, 0, off, or no for providers that do not support
# OpenAI's response_format={"type":"json_object"} (e.g. some Ollama/vLLM builds).
WIKI_USE_JSON_RESPONSE_FORMAT=true

# Number of retries on transient chat errors (0 disables retries).
WIKI_CHAT_MAX_RETRIES=2

# Local wiki paths
WIKI_RAW_DIR=raw
WIKI_OUTPUT_DIR=wiki
WIKI_BACKUP_DIR_NAME=.backups
WIKI_SCHEMA_FILE=schema.md

# Formatting and context limits
WIKI_DATE_FORMAT=%Y-%m-%d
WIKI_MAX_SOURCE_CHARS=100000
WIKI_MAX_EXISTING_FULL_PAGES=8
WIKI_MAX_EXISTING_FULL_CHARS_PER_PAGE=12000
# Caps the number of page summaries sent to the model during ingest.
WIKI_MAX_EXISTING_SUMMARIES=200
